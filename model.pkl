{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyPVSVdqURwZQNJSUaZoKEGT"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":2,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"F0fvgzDih2Uf","executionInfo":{"status":"ok","timestamp":1776045134915,"user_tz":-60,"elapsed":245,"user":{"displayName":"Prince Obol","userId":"17575235885273382062"}},"outputId":"b2d628fa-b03d-4f14-8c01-2c5a4811e587"},"outputs":[{"output_type":"stream","name":"stdout","text":["✅ High-Accuracy model.pkl created successfully!\n"]}],"source":["import pandas as pd\n","import numpy as np\n","from sklearn.ensemble import RandomForestRegressor\n","import joblib\n","\n","# 1. CREATE SYNTHETIC \"EXPERT\" DATA\n","# (In a real studio, you'd load a CSV of 5,000 historical matches here)\n","data = {\n","    'attack_strength': [0.8, 0.2, 0.5, 0.9, 0.1, 0.7, 0.4, 0.3],\n","    'defense_weakness': [0.2, 0.9, 0.5, 0.1, 0.8, 0.3, 0.6, 0.7],\n","    'tempo':           [0.7, 0.3, 0.5, 0.8, 0.2, 0.6, 0.4, 0.5],\n","    'context':         [1.2, 0.6, 1.0, 1.3, 0.5, 1.1, 0.8, 0.7],\n","    'is_home':         [1, 0, 1, 0, 1, 0, 1, 0],\n","    'actual_goals':    [3.1, 0.2, 1.5, 2.8, 0.4, 2.1, 1.1, 0.9] # Target\n","}\n","\n","df = pd.DataFrame(data)\n","\n","# 2. DEFINE FEATURES AND TARGET\n","# These MUST match the order in your app's build_goal_features function\n","X = df[['attack_strength', 'defense_weakness', 'tempo', 'context', 'is_home']]\n","y = df['actual_goals']\n","\n","# 3. TRAIN THE BRAIN (Top Accuracy Config)\n","model = RandomForestRegressor(\n","    n_estimators=200,\n","    max_depth=10,\n","    random_state=42\n",")\n","model.fit(X, y)\n","\n","# 4. SAVE THE BRAIN\n","joblib.dump(model, 'model.pkl')\n","print(\"✅ High-Accuracy model.pkl created successfully!\")"]}]}